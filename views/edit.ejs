<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/edit.css">
    <title>Edit Message</title>
</head>
<body>
    <div class="edit-card">
        <h2>Edit Chat</h2>

        <div class="user-badges">
            <span class="badge">From: <%= chat.from %></span>
            <span class="badge">To: <%= chat.to %></span>
        </div>

        <form action="/chats/<%= chat._id %>?_method=PUT" method="post" class="edit-form">
            <textarea name="msg" rows="4"><%= chat.msg %></textarea>
            
            <div class="btn-group">
                <button type="submit" class="save-btn">Save Changes</button>
                <a href="/chats" class="cancel-link">Go back to all chats</a>
            </div>
        </form>
    </div>
</body>
</html>